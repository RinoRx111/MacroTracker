{
  "name": "macro-tracker-frontend",
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "electron": "electron .",
    "package": "electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
    "recharts": "^2.10.0",
    "framer-motion": "^10.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "electron": "^42.4.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.macrotracker.app",
    "productName": "MacroTracker",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "main.cjs",
      "package.json",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/backend_server.exe",
        "to": "backend_server.exe"
      },
      {
        "from": "dist",
        "to": "dist"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signtoolOptions": {
        "sign": "./sign.cjs"
      }
    }
  }
}
